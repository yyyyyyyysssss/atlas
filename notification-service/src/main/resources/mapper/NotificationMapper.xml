<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.atlas.notification.mapper.NotificationMapper">

    <resultMap type="com.atlas.notification.domain.entity.Notification" id="NotificationMap">
        <result property="id" column="id" jdbcType="INTEGER"/>
        <result property="title" column="title" jdbcType="VARCHAR"/>
        <result property="channelType" column="channel_type" jdbcType="VARCHAR"/>
        <result property="templateCode" column="template_code" jdbcType="VARCHAR"/>
        <result property="content" column="content" jdbcType="VARCHAR" typeHandler="com.baomidou.mybatisplus.extension.handlers.JacksonTypeHandler"/>
        <result property="status" column="status" jdbcType="VARCHAR"/>
        <result property="category" column="category" jdbcType="VARCHAR"/>
        <result property="failReason" column="fail_reason" jdbcType="VARCHAR"/>
        <result property="sendTime" column="send_time" jdbcType="TIMESTAMP"/>
        <result property="params" column="params" jdbcType="VARCHAR" typeHandler="com.baomidou.mybatisplus.extension.handlers.JacksonTypeHandler"/>
        <result property="ext" column="ext" jdbcType="VARCHAR" typeHandler="com.baomidou.mybatisplus.extension.handlers.JacksonTypeHandler"/>
        <result property="creatorId" column="creator_id" jdbcType="INTEGER"/>
        <result property="creatorName" column="creator_name" jdbcType="VARCHAR"/>
        <result property="createTime" column="create_time" jdbcType="TIMESTAMP"/>
        <result property="updaterId" column="updater_id" jdbcType="INTEGER"/>
        <result property="updaterName" column="updater_name" jdbcType="VARCHAR"/>
        <result property="updateTime" column="update_time" jdbcType="TIMESTAMP"/>
    </resultMap>

    <resultMap id="UserNotificationMap" type="com.atlas.notification.domain.vo.UserNotificationVO">
        <id property="id" column="id" />
        <result property="notificationId" column="notification_id" />
        <result property="isRead" column="is_read" />
        <result property="title" column="title" />
        <result property="category" column="category" />
        <result property="sendTime" column="send_time" />
        <result property="content" column="content" typeHandler="com.baomidou.mybatisplus.extension.handlers.JacksonTypeHandler" />
    </resultMap>

    <select id="selectUserNotifications" resultMap="UserNotificationMap">
        SELECT
            t.id,
            t.notification_id,
            t.is_read,
            f.title,
            f.category,
            f.send_time,
            f.content
        FROM
            ntf_notification_receiver t
        LEFT JOIN ntf_notification f ON t.notification_id = f.id
        WHERE
            t.receiver_id = #{userId}
          AND f.channel_type = 'INBOX'
          AND f.status = 'SENT'
        ORDER BY t.receive_time DESC
    </select>

</mapper>

